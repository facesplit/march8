{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",

  "permission": {
    "bash": "ask",
    "edit": "ask",
    "webfetch": "deny"
  },

  "plugin": [
    "@howaboua/opencode-planning-toolkit@latest"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "oauth": false,
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_KEY"
      }
    },

    "serena": {
      "type": "local",
      "command": [
        "C:\\Users\\user\\.local\\bin\\uvx.exe",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--transport",
        "stdio",
        "--context",
        "desktop-app",
        "--project-from-cwd"
      ],
      "enabled": true,
      "environment": {
        "PYTHONIOENCODING": "utf-8"
      }
    }
  }
}